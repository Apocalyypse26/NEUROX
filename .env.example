# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL (TRIBE v2 Pipeline)
# SET THIS PER ENVIRONMENT:
# Development: http://localhost:8000
# Production: https://your-backend-domain.com
VITE_API_URL=

# TRIBE Configuration
USE_REAL_TRIBE=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Stripe Configuration (Backend only)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Supabase Backend Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# AI Analysis (GPT-4o Vision for meme/video analysis)
OPENAI_API_KEY=sk-proj-your-openai-key-here

# --- Job Pipeline Timeouts (Backend) ---
MEDIA_DOWNLOAD_TIMEOUT=30
PREPROCESS_TIMEOUT=60
OCR_TIMEOUT=120
TRIBE_TIMEOUT=60

# --- File Upload Limits (Backend) ---
MAX_IMAGE_SIZE_MB=8
MAX_VIDEO_SIZE_MB=25
MAX_VIDEO_DURATION_SEC=20
MAX_FILES_PER_PROJECT=10

# --- Job Cleanup (Backend) ---
JOB_CLEANUP_INTERVAL_SECONDS=300
MAX_JOB_AGE_SECONDS=3600

# --- Frontend Polling (Optional) ---
VITE_POLL_INTERVAL=1500
VITE_MAX_POLL_ATTEMPTS=60
